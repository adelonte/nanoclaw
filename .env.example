ASSISTANT_HAS_OWN_NUMBER=
TELEGRAM_BOT_TOKEN=

# Connector Gateway — OAuth callback server (non-sensitive, safe in .env)
# CONNECTOR_CALLBACK_PORT=3456
# CONNECTOR_CALLBACK_HOST=localhost

# ─────────────────────────────────────────────────────────────────────────────
# Connector OAuth client credentials are NOT stored in .env.
# They are loaded at runtime from the OneCLI Agent Vault.
#
# Register each provider's credentials before starting NanoClaw:
#
#   Gmail:
#     onecli secrets create \
#       --name connector/client/gmail \
#       --type api_key \
#       --value '{"clientId":"YOUR_CLIENT_ID","clientSecret":"YOUR_CLIENT_SECRET"}'
#
#   GitHub:
#     onecli secrets create \
#       --name connector/client/github \
#       --type api_key \
#       --value '{"clientId":"YOUR_CLIENT_ID","clientSecret":"YOUR_CLIENT_SECRET"}'
#
# Verify: onecli secrets list
# ─────────────────────────────────────────────────────────────────────────────
